APP_NAME=fraud-investigation-backend
ENVIRONMENT=local
LOG_LEVEL=info
LOG_FORMAT=json
SYNTHETIC_DATA_PATH=../data/synthetic
AUTH_MODE=local
OBSERVABILITY_ENABLED=true
OBSERVABILITY_MODE=local
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=
TELEMETRY_SERVICE_NAME=fraud-investigation-platform
TELEMETRY_ENVIRONMENT=local
TELEMETRY_SAMPLE_RATE=1.0
TELEMETRY_ENABLE_API=true
TELEMETRY_ENABLE_AGENT=true
TELEMETRY_ENABLE_RAG=true
TELEMETRY_ENABLE_LLM=true
TELEMETRY_ENABLE_BUSINESS=true
TELEMETRY_ENABLE_SECURITY=true
TELEMETRY_LOG_PROMPTS=false
TELEMETRY_LOG_RESPONSES=false
TELEMETRY_LOG_PII=false
TOKEN_COST_INPUT_PER_1K=0.0000
TOKEN_COST_OUTPUT_PER_1K=0.0000
CURRENCY=USD
AI_PROVIDER=local
AI_PROVIDER_ALLOW_FALLBACK=true
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_API_AUDIENCE=
ENTRA_AUTHORITY=
AZURE_OPENAI_ENDPOINT=https://placeholder.openai.azure.com
AZURE_OPENAI_API_KEY=placeholder-only
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_REASONING_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_REQUEST_TIMEOUT_SECONDS=60
AZURE_OPENAI_MAX_RETRIES=3
AZURE_OPENAI_TEMPERATURE=0.2
AZURE_OPENAI_MAX_TOKENS=2000
USE_AZURE_OPENAI=false
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://placeholder.services.ai.azure.com
AZURE_AI_FOUNDRY_AGENT_ID=placeholder-agent-id
AZURE_AI_FOUNDRY_CONNECTION_NAME=placeholder-connection-name
AZURE_AI_FOUNDRY_THREAD_ID=placeholder-thread-id
USE_AZURE_AI_FOUNDRY_AGENT_SERVICE=false
LLM_ENABLE_JSON_MODE=true
LLM_ENABLE_STREAMING=false
LLM_LOG_PROMPTS=false
LLM_LOG_RESPONSES=false
AI_SAFETY_REQUIRE_HUMAN_REVIEW=true
AI_SAFETY_REQUIRE_CITATIONS=true
AI_SAFETY_MAX_RECOMMENDATION_CONFIDENCE=HIGH
AZURE_AI_SEARCH_ENDPOINT=https://placeholder.search.windows.net
AZURE_AI_SEARCH_API_KEY=placeholder-only
AZURE_SEARCH_ENDPOINT=https://placeholder.search.windows.net
AZURE_SEARCH_ADMIN_KEY=placeholder-only
AZURE_SEARCH_QUERY_KEY=placeholder-only
AZURE_SEARCH_POLICY_INDEX=fraud-policies
AZURE_SEARCH_CASE_INDEX=historical-fraud-cases
AZURE_SEARCH_HISTORICAL_CASE_INDEX=historical-fraud-cases
AZURE_SEARCH_EVIDENCE_INDEX=case-evidence
AZURE_SEARCH_SEMANTIC_CONFIG=fraud-semantic-config
